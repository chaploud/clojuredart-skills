#!/usr/bin/env bash
set -euo pipefail

# cljd-ui-tree - Get accessibility tree from iOS Simulator via AXe
# Usage: cljd-ui-tree [--compact] [--interactive]

MODE="full"

while [[ $# -gt 0 ]]; do
  case "$1" in
    --compact)
      MODE="compact"
      shift
      ;;
    --interactive)
      MODE="interactive"
      shift
      ;;
    --help|-h)
      echo "Usage: cljd-ui-tree [--compact] [--interactive]"
      echo ""
      echo "Options:"
      echo "  --compact      One line per element with coordinates (token-efficient)"
      echo "  --interactive  Show only buttons, text fields, and other interactive elements"
      echo ""
      echo "Requires: axe (brew tap cameroncooke/axe && brew install axe)"
      exit 0
      ;;
    *)
      echo "ERROR: Unknown option: $1" >&2
      exit 1
      ;;
  esac
done

if ! command -v axe &>/dev/null; then
  echo "ERROR: axe is not installed." >&2
  echo "Install: brew tap cameroncooke/axe && brew install axe" >&2
  exit 1
fi

# Get booted device UDID
UDID=$(xcrun simctl list devices booted --json | python3 -c "
import json, sys
data = json.load(sys.stdin)
for runtime, devices in data.get('devices', {}).items():
    for d in devices:
        if d.get('state') == 'Booted':
            print(d['udid'])
            sys.exit(0)
sys.exit(1)
" 2>/dev/null) || {
  echo "ERROR: No booted iOS Simulator found." >&2
  exit 1
}

# AXe field mapping:
#   type     -> element type (Button, Image, StaticText, TextField, etc.)
#   AXLabel  -> accessibility label
#   AXValue  -> current value
#   frame    -> {x, y, width, height}
#   role     -> AX role (AXButton, AXImage, AXStaticText, etc.)

SKIP_TYPES='AXApplication|AXWindow|AXGroup|AXOther|AXScrollArea|AXList|AXCell|AXLayoutArea|AXWebArea|AXTable|AXRow|AXColumn'

case "$MODE" in
  full)
    axe describe-ui --udid "$UDID" 2>/dev/null
    ;;
  compact)
    axe describe-ui --udid "$UDID" 2>/dev/null | python3 -c "
import json, sys

SKIP = {'AXApplication', 'AXWindow', 'AXGroup', 'AXOther', 'AXScrollArea',
        'AXList', 'AXCell', 'AXLayoutArea', 'AXWebArea', 'AXTable', 'AXRow', 'AXColumn'}

def walk(node):
    results = []
    role = node.get('role', '') or ''
    typ = node.get('type', '') or ''
    label = node.get('AXLabel') or ''
    value = node.get('AXValue') or ''
    frame = node.get('frame', {})
    x = frame.get('x', 0)
    y = frame.get('y', 0)
    w = frame.get('width', 0)
    h = frame.get('height', 0)

    if role not in SKIP and typ:
        parts = [f'[{typ}]']
        if label:
            parts.append(f'\"{label}\"')
        parts.append(f'(x:{int(x)} y:{int(y)} w:{int(w)} h:{int(h)})')
        if value:
            parts.append(f'value=\"{value}\"')
        results.append(' '.join(parts))

    for child in node.get('children', []):
        results.extend(walk(child))
    return results

try:
    data = json.load(sys.stdin)
    nodes = data if isinstance(data, list) else [data]
    for node in nodes:
        for line in walk(node):
            print(line)
except Exception as e:
    print(f'Error: {e}', file=sys.stderr)
    sys.exit(1)
"
    ;;
  interactive)
    axe describe-ui --udid "$UDID" 2>/dev/null | python3 -c "
import json, sys

INTERACTIVE = {'AXButton', 'AXTextField', 'AXSecureTextField', 'AXTextArea',
               'AXSwitch', 'AXSlider', 'AXPicker', 'AXLink', 'AXTab',
               'AXCheckBox', 'AXRadioButton', 'AXToggle', 'AXStepper',
               'AXSegmentedControl', 'AXPopUpButton', 'AXMenuItem',
               'AXComboBox', 'AXIncrementor'}

def walk(node):
    results = []
    role = node.get('role', '') or ''
    typ = node.get('type', '') or ''
    label = node.get('AXLabel') or ''
    value = node.get('AXValue') or ''
    frame = node.get('frame', {})
    x = frame.get('x', 0)
    y = frame.get('y', 0)
    w = frame.get('width', 0)
    h = frame.get('height', 0)

    if role in INTERACTIVE:
        parts = [f'[{typ}]']
        if label:
            parts.append(f'\"{label}\"')
        parts.append(f'(x:{int(x)} y:{int(y)} w:{int(w)} h:{int(h)})')
        if value:
            parts.append(f'value=\"{value}\"')
        results.append(' '.join(parts))

    for child in node.get('children', []):
        results.extend(walk(child))
    return results

try:
    data = json.load(sys.stdin)
    nodes = data if isinstance(data, list) else [data]
    for node in nodes:
        for line in walk(node):
            print(line)
except Exception as e:
    print(f'Error: {e}', file=sys.stderr)
    sys.exit(1)
"
    ;;
esac
