#!/usr/bin/env bash
set -euo pipefail

# cljd-swipe - Swipe on iOS Simulator via AXe
# Usage: cljd-swipe DIRECTION | cljd-swipe X1 Y1 X2 Y2

if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
  echo "Usage: cljd-swipe DIRECTION"
  echo "       cljd-swipe X1 Y1 X2 Y2"
  echo ""
  echo "Directions: up, down, left, right"
  echo "Coordinates: swipe from (X1,Y1) to (X2,Y2)"
  echo ""
  echo "Requires: axe (brew tap cameroncooke/axe && brew install axe)"
  exit 0
fi

if [[ $# -lt 1 ]]; then
  echo "Usage: cljd-swipe DIRECTION | cljd-swipe X1 Y1 X2 Y2" >&2
  exit 1
fi

if ! command -v axe &>/dev/null; then
  echo "ERROR: axe is not installed." >&2
  echo "Install: brew tap cameroncooke/axe && brew install axe" >&2
  exit 1
fi

UDID=$(xcrun simctl list devices booted --json | python3 -c "
import json, sys
data = json.load(sys.stdin)
for runtime, devices in data.get('devices', {}).items():
    for d in devices:
        if d.get('state') == 'Booted':
            print(d['udid'])
            sys.exit(0)
sys.exit(1)
" 2>/dev/null) || {
  echo "ERROR: No booted iOS Simulator found." >&2
  exit 1
}

if [[ $# -eq 1 ]]; then
  DIRECTION="$1"
  case "$DIRECTION" in
    up)
      axe swipe --start-x 200 --start-y 600 --end-x 200 --end-y 200 --udid "$UDID" 2>/dev/null
      ;;
    down)
      axe swipe --start-x 200 --start-y 200 --end-x 200 --end-y 600 --udid "$UDID" 2>/dev/null
      ;;
    left)
      axe swipe --start-x 350 --start-y 400 --end-x 50 --end-y 400 --udid "$UDID" 2>/dev/null
      ;;
    right)
      axe swipe --start-x 50 --start-y 400 --end-x 350 --end-y 400 --udid "$UDID" 2>/dev/null
      ;;
    *)
      echo "ERROR: Unknown direction: $DIRECTION (use up, down, left, right)" >&2
      exit 1
      ;;
  esac
  echo "Swiped $DIRECTION"
elif [[ $# -eq 4 ]]; then
  axe swipe --start-x "$1" --start-y "$2" --end-x "$3" --end-y "$4" --udid "$UDID" 2>/dev/null
  echo "Swiped from ($1,$2) to ($3,$4)"
else
  echo "Usage: cljd-swipe DIRECTION | cljd-swipe X1 Y1 X2 Y2" >&2
  exit 1
fi
