#!/usr/bin/env bash
set -euo pipefail

# cljd-type - Type text into focused element on iOS Simulator via AXe
# Usage: cljd-type "text to type"

if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
  echo 'Usage: cljd-type "text to type"'
  echo ""
  echo "Types text into the currently focused text field."
  echo "Requires: axe (brew tap cameroncooke/axe && brew install axe)"
  exit 0
fi

if [[ $# -lt 1 ]]; then
  echo 'Usage: cljd-type "text to type"' >&2
  exit 1
fi

if ! command -v axe &>/dev/null; then
  echo "ERROR: axe is not installed." >&2
  echo "Install: brew tap cameroncooke/axe && brew install axe" >&2
  exit 1
fi

UDID=$(xcrun simctl list devices booted --json | python3 -c "
import json, sys
data = json.load(sys.stdin)
for runtime, devices in data.get('devices', {}).items():
    for d in devices:
        if d.get('state') == 'Booted':
            print(d['udid'])
            sys.exit(0)
sys.exit(1)
" 2>/dev/null) || {
  echo "ERROR: No booted iOS Simulator found." >&2
  exit 1
}

axe type --udid "$UDID" --text "$1" 2>/dev/null
echo "Typed: $1"
